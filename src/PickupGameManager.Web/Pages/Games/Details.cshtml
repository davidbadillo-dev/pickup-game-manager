@page "/g/{id:guid}"
@model PickupGameManager.Web.Pages.Games.DetailsModel
@{
    ViewData["Title"] = Model.Game!.Title;
    var shareUrl = $"{Request.Scheme}://{Request.Host}{Url.Page("/Games/Details", values: new { id = Model.Game.Id })}";
    var spotsLeftLabel = Model.SpotsRemaining == 1 ? "1 spot left" : $"{Model.SpotsRemaining} spots left";
    var goingNamesJson = System.Text.Json.JsonSerializer.Serialize(Model.GoingPlayers.Select(p => p.Name));
    var waitlistNamesJson = System.Text.Json.JsonSerializer.Serialize(Model.WaitlistedPlayers.Select(p => p.Name));
}

<div class="game-details-page">
    <h1 class="mb-2">@Model.Game.Title</h1>

    <div id="player-status-alert" class="alert alert-success py-2 mb-3 d-none" role="status"></div>
    <p id="player-status-hint" class="text-muted small mb-3 d-none">You are not joined yet.</p>

    @if (TempData["LeaveNotice"] is string leaveNotice && leaveNotice.Length > 0)
    {
        var leaveNoticeName = TempData["LeaveNoticeName"] as string ?? string.Empty;
        <div class="alert alert-secondary py-2 mb-3" role="status" id="leave-notice" data-notice-name="@leaveNoticeName">@leaveNotice</div>
    }

    <div class="card mb-3">
        <div class="card-body py-3">
            <dl class="row mb-0">
                <dt class="col-4 col-sm-3">Where</dt>
                <dd class="col-8 col-sm-9">@Model.Game.Location</dd>

                <dt class="col-4 col-sm-3">When</dt>
                <dd class="col-8 col-sm-9">@Model.Game.ScheduledAt.ToLocalTime().ToString("f")</dd>

                <dt class="col-4 col-sm-3">Players</dt>
                <dd class="col-8 col-sm-9">@Model.GoingCount / @Model.Game.MaxPlayers</dd>

                <dt class="col-4 col-sm-3">Spots</dt>
                <dd class="col-8 col-sm-9">@spotsLeftLabel</dd>
            </dl>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-12 col-lg-6">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="h5">Join this game</h2>
                    <form method="post" asp-page-handler="Join" class="mb-0" id="join-form">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <div class="mb-2">
                            <label asp-for="Input.PlayerName" class="form-label"></label>
                            <input asp-for="Input.PlayerName" class="form-control" autocomplete="name" id="join-player-name" />
                            <span asp-validation-for="Input.PlayerName" class="text-danger"></span>
                        </div>
                        <button type="submit" class="btn btn-primary" id="join-button">Join</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-6">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="h5">Leave this game</h2>
                    <form method="post" asp-page="/Games/Leave" asp-route-id="@Model.Game.Id" class="mb-0" id="leave-form">
                        <div class="mb-2">
                            <label class="form-label" for="leave-player-name">Your name</label>
                            <input id="leave-player-name" name="PlayerName" class="form-control" maxlength="200" autocomplete="name" />
                        </div>
                        <button type="submit" class="btn btn-outline-secondary" id="leave-button">Leave game</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-12 col-md-6">
            <section class="card h-100 roster-card roster-card-going">
                <div class="card-body">
                    <h2 class="h5 mb-2">Going (@Model.GoingCount)</h2>
                    @if (Model.GoingPlayers.Count == 0)
                    {
                        <p class="text-muted mb-0">No one yet.</p>
                    }
                    else
                    {
                        <ul class="list-unstyled mb-0">
                            @foreach (var p in Model.GoingPlayers)
                            {
                                <li class="py-1 border-bottom">@p.Name</li>
                            }
                        </ul>
                    }
                </div>
            </section>
        </div>
        <div class="col-12 col-md-6">
            <section class="card h-100 roster-card roster-card-waitlist">
                <div class="card-body">
                    <h2 class="h5 mb-2">Waitlist (@Model.WaitlistedPlayers.Count)</h2>
                    @if (Model.WaitlistedPlayers.Count == 0)
                    {
                        <p class="text-muted mb-0">Nobody on the waitlist.</p>
                    }
                    else
                    {
                        <ul class="list-unstyled mb-0">
                            @foreach (var p in Model.WaitlistedPlayers)
                            {
                                <li class="py-1 border-bottom">@p.Name</li>
                            }
                        </ul>
                    }
                </div>
            </section>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h2 class="h6 card-title">Share this game</h2>
            <p class="card-text small text-muted mb-2">Send players this link to open the game page.</p>
            <div class="input-group">
                <input type="text" class="form-control font-monospace small" readonly value="@shareUrl" id="share-url" />
                <button type="button" class="btn btn-outline-primary" id="copy-share">Copy</button>
            </div>
        </div>
    </div>

    <p class="mb-0"><a asp-page="/Index">← Home</a></p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const playerNameStorageKey = 'pickupGameManager.playerName';
        const joinInput = document.getElementById('join-player-name');
        const leaveInput = document.getElementById('leave-player-name');
        const joinForm = document.getElementById('join-form');
        const leaveForm = document.getElementById('leave-form');
        const joinButton = document.getElementById('join-button');
        const leaveButton = document.getElementById('leave-button');
        const playerStatusAlert = document.getElementById('player-status-alert');
        const playerStatusHint = document.getElementById('player-status-hint');
        const leaveNotice = document.getElementById('leave-notice');
        const goingNames = @Html.Raw(goingNamesJson);
        const waitlistNames = @Html.Raw(waitlistNamesJson);

        const getSavedPlayerName = () => {
            try {
                return localStorage.getItem(playerNameStorageKey) || '';
            } catch {
                return '';
            }
        };

        const savePlayerName = (value) => {
            const trimmed = value.trim();
            if (!trimmed) return;
            try {
                localStorage.setItem(playerNameStorageKey, trimmed);
            } catch {
                // Ignore browsers that block storage in privacy modes.
            }
        };

        const normalize = (value) => value.trim().toLowerCase();

        const computeStatus = (name) => {
            const normalized = normalize(name);
            if (!normalized) return null;

            if (goingNames.some(n => normalize(n) === normalized)) {
                return 'Going';
            }

            if (waitlistNames.some(n => normalize(n) === normalized)) {
                return 'Waitlist';
            }

            return null;
        };

        const renderStatus = (status) => {
            const currentName = joinInput?.value ?? '';
            const leaveNoticeName = leaveNotice?.dataset.noticeName ?? '';

            if (leaveNotice) {
                const noticeTargetsCurrentName = leaveNoticeName
                    ? normalize(leaveNoticeName) === normalize(currentName)
                    : !normalize(currentName);
                leaveNotice.classList.toggle('d-none', !noticeTargetsCurrentName);
            }

            if (status) {
                if (playerStatusAlert) {
                    playerStatusAlert.textContent = `Your status: ${status}`;
                    playerStatusAlert.classList.remove('d-none');
                }

                playerStatusHint?.classList.add('d-none');
                if (joinButton) joinButton.disabled = true;
                if (leaveButton) leaveButton.disabled = false;
                return;
            }

            playerStatusAlert?.classList.add('d-none');
            playerStatusHint?.classList.remove('d-none');
            if (joinButton) joinButton.disabled = false;
            if (leaveButton) leaveButton.disabled = true;
        };

        const syncNameAndStatus = () => {
            const currentName = joinInput?.value ?? '';
            if (leaveInput) {
                leaveInput.value = currentName;
            }

            const status = computeStatus(currentName);
            renderStatus(status);
            savePlayerName(currentName);
        };

        const savedPlayerName = getSavedPlayerName();
        if (joinInput && !joinInput.value.trim() && savedPlayerName) {
            joinInput.value = savedPlayerName;
        }

        if (leaveInput && !leaveInput.value.trim() && savedPlayerName) {
            leaveInput.value = savedPlayerName;
        }

        joinInput?.addEventListener('input', () => {
            if (leaveInput) {
                leaveInput.value = joinInput.value;
            }

            const status = computeStatus(joinInput.value);
            renderStatus(status);
        });

        joinInput?.addEventListener('blur', () => syncNameAndStatus());
        leaveInput?.addEventListener('input', () => {
            if (joinInput) {
                joinInput.value = leaveInput.value;
            }

            const status = computeStatus(leaveInput.value);
            renderStatus(status);
        });
        leaveInput?.addEventListener('blur', () => syncNameAndStatus());
        joinForm?.addEventListener('submit', () => savePlayerName(joinInput?.value ?? ''));
        leaveForm?.addEventListener('submit', () => savePlayerName(leaveInput?.value ?? ''));
        syncNameAndStatus();

        document.getElementById('copy-share')?.addEventListener('click', async () => {
            const input = document.getElementById('share-url');
            if (!input) return;
            try {
                await navigator.clipboard.writeText(input.value);
            } catch {
                input.select();
                document.execCommand('copy');
            }
        });
    </script>
}
